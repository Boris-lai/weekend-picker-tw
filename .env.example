# Anthropic API key — required for /api/generate
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Public site URL — used by metadata, sitemap.ts, robots.ts, OG image absolute URLs
# Local dev: leave blank (defaults to http://localhost:3000)
# Production: set to your Vercel domain, e.g. https://weekend-picker.vercel.app
NEXT_PUBLIC_SITE_URL=
