# Anthropic API key — required for /api/generate
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Public site URL — used by metadata, sitemap.ts, robots.ts, OG image absolute URLs
# Local dev: leave blank (defaults to http://localhost:3000)
# Production: set to your Vercel domain, e.g. https://weekend-picker.vercel.app
NEXT_PUBLIC_SITE_URL=

# Upstash Redis — IP-based rate limit on /api/generate
# In Vercel: Storage → Create → Upstash for Redis auto-injects these as
# KV_REST_API_URL / KV_REST_API_TOKEN (newer Marketplace prefix). The
# code also accepts UPSTASH_REDIS_REST_URL / *_TOKEN if you wire it
# yourself. Local dev: optional — if neither pair is set, /api/generate
# fails open (no rate limit).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
